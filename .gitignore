# Allow tracked testdata FITS files (Git LFS)
!packages/testdata/data/
!packages/testdata/data/**

# Allow tracked test fixtures (the bare `data` rule above would hide these)
!packages/obs_stips/tests/data/
!packages/obs_stips/tests/data/**
# ...but keep build artifacts under it ignored (the `**` negation re-included them)
packages/obs_stips/tests/data/**/__pycache__/
packages/obs_stips/tests/data/**/*.pyc

# Defect visualization outputs
packages/defects/defects_tools/defects/defects_*/
**/defects/defects/

# DIA pipeline outputs
*.csv

# Quantum graphs
*.qg
*.dot

