# Example environment configuration for Nickel Processing Suite
# Copy this file to .env and customize for your setup
# For multiple repos, create separate files like repo1.env, repo2.env, etc.

# ============================================================================
# BUTLER REPOSITORY (Required)
# ============================================================================
# Path to your Butler repository
REPO=/path/to/butler/repo

# ============================================================================
# LSST STACK (Required)
# ============================================================================
# Path to LSST Science Pipelines installation
STACK_DIR=/path/to/lsst_stack

# Path to Nickel Processing Suite repo (or packages/obs_nickel for EUPS)
OBS_NICKEL=/path/to/nickel_processing_suite

# ============================================================================
# DATA PATHS (Required)
# ============================================================================
# Parent directory containing raw data (organized as ${RAW_PARENT_DIR}/${NIGHT}/raw/)
RAW_PARENT_DIR=/path/to/raw/data

# Reference catalog repository
REFCAT_REPO=/path/to/refcat/repo

# Calibration products directory (from LSST stack)
CP_PIPE_DIR=${STACK_DIR}/cp_pipe

# ============================================================================
# LICK ARCHIVE (Optional - for automatic data download)
# ============================================================================
# Path to local copy of lick_searchable_archive
LICK_ARCHIVE_DIR=/path/to/lick_searchable_archive

# Lick Observatory archive URL
LICK_ARCHIVE_URL=https://archive.ucolick.org/archive

# Instrument identifier for archive
LICK_ARCHIVE_INSTR=NICKEL_DIR
