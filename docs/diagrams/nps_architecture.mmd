graph TD
  %% Entry points
  User["User or Automation"] --> CLI["nickel CLI - packages/data_tools/src/obs_nickel_data_tools/cli.py"]
  CLI --> Config["core/config.py - env, profile, YAML env"]
  CLI --> Orchestrator["core/run.py - YAML orchestration"]
  CLI --> Commands["core modules - bootstrap, calibs, science, dia, ps1_template, fphot, lightcurve, bps"]

  %% Stack activation + LSST
  Commands --> Stack["core/stack.py - run_with_stack"]
  Stack --> LSST["LSST stack env - loadLSST zsh/bash/sh; setup lsst_distrib; setup obs_nickel + obs_nickel_data"]
  LSST --> Butler["butler CLI / lsst.daf.butler"]
  LSST --> Pipetask["pipetask CLI / pipelines"]

  %% Monorepo packages
  subgraph "NPS Monorepo"
    data_tools["data_tools - CLI + core + pipeline_tools"]
    obs_nickel["obs_nickel - instrument + pipelines + tasks"]
    obs_nickel_data["obs_nickel_data - curated calibrations"]
    refcats["refcats - refcat scripts/helpers"]
    defects["defects - defect generation tools"]
    lick_archive["lick_searchable_archive - archive client"]
    scripts["scripts/pipeline - legacy shell workflows"]
  end

  data_tools --> obs_nickel
  data_tools --> obs_nickel_data
  data_tools --> refcats
  data_tools --> defects
  data_tools --> lick_archive
  data_tools --> scripts

  obs_nickel --> Pipetask
  obs_nickel_data --> Butler
  refcats --> Butler
  defects --> obs_nickel_data

  %% External services
  LickAPI["Lick Archive API"] -->|download| RawData["RAW_PARENT_DIR/night/raw"]
  data_tools -->|fetch_archive_night| LickAPI
  PS1["PS1 MAST"] -->|cutout| ps1ingest["pipeline_tools/ingest_ps1_template.py"]
  data_tools --> ps1ingest
  SIMBAD["SIMBAD/NED"] -->|name resolve| extractLC["pipeline_tools/extract_lightcurve.py"]

  ps1ingest --> Butler
  extractLC --> Butler

  %% Data store
  Butler --> Repo["Butler repo - collections + datasets"]

  %% Optional HPC path
  Commands --> BPS["core/bps.py - bps submit/status/cancel"]
  BPS --> LSST
  BPS --> HPC["Slurm/HTCondor/local via BPS/Parsl"]
