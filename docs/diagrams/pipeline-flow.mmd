%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#4a90d9', 'primaryTextColor': '#fff', 'primaryBorderColor': '#2d5986', 'lineColor': '#5c5c5c'}}}%%

flowchart TD
    subgraph Input["Input Data"]
        Raw["Raw FITS Files<br/>from Nickel Telescope"]
        RefCats["Reference Catalogs<br/>(Gaia DR3, PS1, MONSTER)"]
        PS1Img["PS1 Survey Images<br/>(r/i bands)"]
    end

    subgraph Step0["Step 0: Bootstrap (One-time)"]
        CreateRepo["Create Butler Repository"]
        RegInstr["Register Nickel Instrument"]
        IngestRef["Ingest Reference Catalogs"]
        RegSkymap["Register Skymap"]
    end

    subgraph Step1["Step 1: Calibrations (Per Night)"]
        IngestRaw["Ingest Raw Data"]
        WriteCurated["Write Curated Calibrations<br/>(defects from obs_nickel_data)"]
        BuildBias["Build Combined Bias"]
        BuildFlat["Build Combined Flats<br/>(per filter)"]
        CertifyCalib["Certify Calibrations"]
    end

    subgraph Step2["Step 2: Science Processing (Per Night)"]
        ISR["Instrument Signature Removal<br/>(bias, flat, defect correction)"]
        CharImg["Characterize Image<br/>(PSF modeling, background)"]
        CalibImg["Calibrate Image<br/>(WCS fitting, photometry)"]
        Consolidate["Consolidate Catalogs"]
    end

    subgraph Step3["Step 3: Template Preparation"]
        direction LR
        PS1Template["PS1 Template<br/>(download & ingest)"]
        NickelCoadd["Nickel Coadd Template<br/>(stack late-time images)"]
    end

    subgraph Step4["Step 4: Difference Imaging (Per Night, Per Band)"]
        WarpTemplate["Warp Template<br/>to Science Image"]
        SubtractImg["Subtract Images<br/>(AL algorithm)"]
        DetectMeasure["Detect & Measure<br/>Difference Sources"]
    end

    subgraph Step5["Step 5: Forced Photometry"]
        ForcedPhot["Forced Photometry<br/>at Target RA/Dec"]
    end

    subgraph Step6["Step 6: Light Curve"]
        ExtractLC["Extract Light Curve<br/>(query all nights)"]
        PlotLC["Generate Plots"]
        ExportCSV["Export to CSV"]
    end

    subgraph Output["Outputs"]
        Butler["Butler Repository<br/>(all data products)"]
        LCFile["Light Curve CSV"]
        LCPlot["Light Curve Plots"]
        ProcLog["Processing Logs<br/>(JSON)"]
    end

    %% Flow connections
    Raw --> Step0
    RefCats --> IngestRef

    CreateRepo --> RegInstr --> IngestRef --> RegSkymap

    Step0 --> Step1
    Raw --> IngestRaw
    IngestRaw --> WriteCurated --> BuildBias --> BuildFlat --> CertifyCalib

    Step1 --> Step2
    ISR --> CharImg --> CalibImg --> Consolidate

    PS1Img --> PS1Template
    Step2 --> NickelCoadd

    Step2 --> Step4
    Step3 --> Step4

    WarpTemplate --> SubtractImg --> DetectMeasure

    Step4 --> Step5
    ForcedPhot --> Step6

    ExtractLC --> PlotLC --> ExportCSV

    %% Outputs
    Step1 --> Butler
    Step2 --> Butler
    Step4 --> Butler
    Step5 --> Butler
    Step6 --> LCFile
    Step6 --> LCPlot
    Step2 --> ProcLog

    %% Styling
    classDef inputStyle fill:#e8f4f8,stroke:#4a90d9,color:#333
    classDef step0Style fill:#f5f5f5,stroke:#999,color:#333
    classDef step1Style fill:#d4edda,stroke:#28a745,color:#333
    classDef step2Style fill:#cce5ff,stroke:#0056b3,color:#333
    classDef step3Style fill:#fff3cd,stroke:#856404,color:#333
    classDef step4Style fill:#f8d7da,stroke:#721c24,color:#333
    classDef step5Style fill:#e2d5f1,stroke:#6f42c1,color:#333
    classDef step6Style fill:#d1ecf1,stroke:#0c5460,color:#333
    classDef outputStyle fill:#f4f4f4,stroke:#666,color:#333

    class Raw,RefCats,PS1Img inputStyle
    class CreateRepo,RegInstr,IngestRef,RegSkymap step0Style
    class IngestRaw,WriteCurated,BuildBias,BuildFlat,CertifyCalib step1Style
    class ISR,CharImg,CalibImg,Consolidate step2Style
    class PS1Template,NickelCoadd step3Style
    class WarpTemplate,SubtractImg,DetectMeasure step4Style
    class ForcedPhot step5Style
    class ExtractLC,PlotLC,ExportCSV step6Style
    class Butler,LCFile,LCPlot,ProcLog outputStyle
