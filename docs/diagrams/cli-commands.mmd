    classDef orchStyle fill:#fff3cd,stroke:#856404
    classDef bpsStyle fill:#f8d7da,stroke:#721c24
    classDef optStyle fill:#e2d5f1,stroke:#6f42c1
    classDef workflowStyle fill:#d1ecf1,stroke:#0c5460

    class env,bootstrap configStyle
    class download,ps1template dataStyle
    class calibs,science,dia,fphot,lightcurve procStyle
    class run orchStyle
    class submit,status,cancel,list bpsStyle
    class profile,envfile optStyle
    class W1,W2,W3,W4,W5,W6,W7,W8,Q1 workflowStyle
