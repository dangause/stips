%%{init: {'theme': 'base', 'themeVariables': { 'primaryColor': '#4a90d9'}}}%%

flowchart TD
    subgraph Butler["Butler Repository Structure"]
        direction TB

        subgraph Raw["Nickel/raw/"]
            RawNight["YYYYMMDD/"]
            RawTS["timestamp/"]
            RawData["Raw exposures<br/>(bias, flat, science)"]
            RawNight --> RawTS --> RawData
        end

        subgraph Calib["Nickel/calib/"]
            CalibCurrent["current<br/>(CHAIN - points to latest)"]
            CalibCurated["curated<br/>(camera geometry, defects)"]
            CalibNight["YYYYMMDD/<br/>(certified calibs)"]

            subgraph CP["cp/YYYYMMDD/"]
                CPBias["bias/<br/>(combined bias)"]
                CPFlat["flat/<br/>(combined flats per filter)"]
            end

            CalibCurrent -.-> CalibNight
            CalibCurrent -.-> CalibCurated
            CalibNight --> CP
        end

        subgraph Runs["Nickel/runs/YYYYMMDD/"]
            subgraph ProcessCcd["processCcd/timestamp/"]
                ScienceRun["run<br/>(calibrated exposures,<br/>source catalogs)"]
            end

            subgraph Diff["diff/timestamp/"]
                DiffRun["run<br/>(difference images,<br/>DIA source catalogs)"]
            end

            subgraph FPhot["forcedPhotRaDec/timestamp/"]
                FPhotRun["run<br/>(forced photometry<br/>at target coords)"]
            end
        end

        subgraph Templates["templates/"]
            PS1["ps1/{band}<br/>(external PS1 templates)"]
            Deep["deep/tract{N}/{band}<br/>(Nickel coadd templates)"]
        end

        subgraph RefCats["refcats (CHAIN)"]
            Gaia["gaia_dr3"]
            PS1Cat["ps1_pv3_3pi_20170110"]
            Monster["the_monster"]
        end
    end

    subgraph Legend["Collection Types"]
        direction LR
        RunType["RUN - Immutable outputs"]
        ChainType["CHAIN - Mutable pointer"]
        TagType["TAGGED - Label for runs"]
    end

    %% Styling
    classDef rawStyle fill:#e8f4f8,stroke:#4a90d9
    classDef calibStyle fill:#d4edda,stroke:#28a745
    classDef runStyle fill:#cce5ff,stroke:#0056b3
    classDef templateStyle fill:#fff3cd,stroke:#856404
    classDef refcatStyle fill:#f8d7da,stroke:#721c24
    classDef chainStyle fill:#f5f5f5,stroke:#999,stroke-dasharray: 5 5

    class RawNight,RawTS,RawData rawStyle
    class CalibCurated,CalibNight,CPBias,CPFlat calibStyle
    class CalibCurrent chainStyle
    class ScienceRun,DiffRun,FPhotRun runStyle
    class PS1,Deep templateStyle
    class Gaia,PS1Cat,Monster refcatStyle
