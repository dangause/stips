# Nickel Processing Suite - Singularity/Apptainer Definition
#
# For HPC environments that require Singularity instead of Docker.
#
# Build from Docker image:
#   # First build Docker image
#   docker build -t nps:latest -f docker/Dockerfile .
#
#   # Convert to Singularity (requires docker2singularity or newer Singularity)
#   singularity build nps.sif docker-daemon://nps:latest
#
# Build directly (if Singularity can access container registry):
#   singularity build nps.sif docker://ghcr.io/lick-observatory/nps:latest
#
# Usage:
#   singularity run -B /path/to/repo:/data/repo \
#                   -B /path/to/raw:/data/raw \
#                   -B /path/to/refcats:/data/refcats \
#                   nps.sif nickel calibs 20230519

Bootstrap: docker
From: nps:latest

%labels
    Author Nickel Processing Suite Team
    Description Nickel Processing Suite for LSST Science Pipelines on HPC
    Version 1.0.0
    URL https://github.com/lick-observatory/nickel_processing_suite

%help
    Nickel Processing Suite (NPS) Container
    ========================================

    This container provides the Nickel Processing Suite for processing
    data from the Nickel 1-meter telescope using LSST Science Pipelines.

    USAGE:
        # Run calibrations
        singularity run nps.sif nickel calibs 20230519

        # Run science processing
        singularity run nps.sif nickel science 20230519

        # Run difference imaging
        singularity run nps.sif nickel dia 20230519 --auto --band r

        # Interactive shell
        singularity shell nps.sif

        # Direct pipetask access
        singularity exec nps.sif pipetask run -b /data/repo ...

    REQUIRED BIND MOUNTS:
        -B /path/to/butler/repo:/data/repo      Butler repository
        -B /path/to/raw/data:/data/raw          Raw FITS files
        -B /path/to/refcats:/data/refcats       Reference catalogs

    OPTIONAL BIND MOUNTS:
        -B /path/to/config:/config              Configuration files (.env)
        -B /path/to/outputs:/data/outputs       Output directory

    ENVIRONMENT VARIABLES:
        REPO=/data/repo
        RAW_PARENT_DIR=/data/raw
        REFCAT_REPO=/data/refcats
        NPS_PROFILE=<profile>                   Load .env.<profile> from /config

    EXAMPLES:
        # Basic processing
        singularity run -B /scratch/repo:/data/repo \
                        -B /archive/raw:/data/raw \
                        -B /common/refcats:/data/refcats \
                        nps.sif nickel calibs 20230519

        # With profile configuration
        singularity run -B /scratch/repo:/data/repo \
                        -B /archive/raw:/data/raw \
                        -B /common/refcats:/data/refcats \
                        -B ./config:/config \
                        --env NPS_PROFILE=2023ixf \
                        nps.sif nickel dia 20230519 --auto

        # BPS submission (local testing)
        singularity run -B ... \
                        nps.sif nickel bps submit science 20230519 --site local

%environment
    # Standard environment variables
    export STACK_DIR=/opt/lsst/software/stack
    export OBS_NICKEL=/opt/nps/packages/obs_nickel
    export OBS_NICKEL_DATA=/opt/nps/packages/obs_nickel_data
    export NPS_ROOT=/opt/nps

    # Default data paths (can be overridden with --env)
    export REPO=/data/repo
    export RAW_PARENT_DIR=/data/raw
    export REFCAT_REPO=/data/refcats

    # Locale settings to avoid encoding issues
    export LC_ALL=C
    export LANG=C

%runscript
    # Execute the entrypoint script with passed arguments
    exec /opt/nps/docker/entrypoint.sh "$@"

%startscript
    # For Singularity instances
    exec /opt/nps/docker/entrypoint.sh "$@"

%test
    # Basic sanity checks during build
    echo "Testing NPS container..."

    # Check that LSST stack is present
    if [ ! -f "${STACK_DIR}/loadLSST.bash" ]; then
        echo "ERROR: LSST stack not found at ${STACK_DIR}"
        exit 1
    fi

    # Check that obs_nickel is present
    if [ ! -d "${OBS_NICKEL}" ]; then
        echo "ERROR: obs_nickel not found at ${OBS_NICKEL}"
        exit 1
    fi

    # Check that nickel CLI is available
    if ! command -v nickel &> /dev/null; then
        echo "WARNING: nickel command not in PATH (will be available after stack activation)"
    fi

    echo "Container tests passed!"
